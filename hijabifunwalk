<!doctype html>
<html lang="ms">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HIJABI FUN Walk 2026</title>
  
  <!-- CDNs for Tailwind CSS and Lucide Icons -->
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap" rel="stylesheet">
  
  <style>
    :root {
      /* Tema Soft Pink / Rose */
      --primary-950: #4c0519; /* dark rose */
      --primary-900: #881337;
      --primary-700: #e11d48; /* vibrant rose/pink */
      --gold: #c99d46;
      --gold-soft: #f6ead0;
      --cream: #fbf8f0;
      --ink: #2a0a14;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: "DM Sans", sans-serif;
      color: var(--ink);
      background: #fdf2f8; /* pink-50 */
    }
    .app-shell { width: 100%; min-height: 100%; }
    .serif { font-family: "Fraunces", serif; }
    
    /* Overlay and Background Patterns */
    .hero-overlay {
      background: linear-gradient(112deg, rgba(136, 19, 55, .94) 0%, rgba(190, 18, 60, .82) 46%, rgba(136, 19, 55, .32) 100%);
    }
    .islamic-pattern {
      background-image: radial-gradient(circle at 1px 1px, rgba(201,157,70,.28) 1px, transparent 0);
      background-size: 18px 18px;
    }
    
    /* Card Styles */
    .section-card {
      border: 1px solid rgba(225, 29, 72, .13);
      box-shadow: 0 14px 34px rgba(76, 5, 25, .07);
    }
    .section-icon {
      width: 42px;
      height: 42px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
      border-radius: 14px;
      background: linear-gradient(135deg, #fff1f2, #f8ebcf);
      color: var(--primary-900);
    }
    
    /* Form Inputs */
    .form-control {
      width: 100%;
      border: 1px solid #fecdd3; /* rose-200 */
      border-radius: 12px;
      background: #fff;
      padding: .78rem .9rem;
      font: inherit;
      color: var(--ink);
      outline: none;
      transition: border-color .18s ease, box-shadow .18s ease;
    }
    .form-control:focus {
      border-color: var(--primary-700);
      box-shadow: 0 0 0 4px rgba(225, 29, 72, .12);
    }
    .form-control:disabled {
      background: #f1f5f9;
      color: #94a3b8;
      cursor: not-allowed;
    }
    .form-control::file-selector-button {
      border: 0;
      border-radius: 8px;
      padding: .48rem .72rem;
      margin-right: .7rem;
      color: #fff;
      background: var(--primary-900);
      font-weight: 700;
      cursor: pointer;
    }
    
    .radio-card {
      border: 2px solid #ffe4e6; /* rose-100 */
      background: #fff;
      transition: all .18s ease;
    }
    .radio-card:has(input:checked) {
      border-color: var(--primary-700);
      background: #fff1f2; /* rose-50 */
      box-shadow: 0 4px 12px rgba(225, 29, 72, .11);
      transform: translateY(-2px);
    }
    .radio-card input { accent-color: var(--primary-700); width: 1.25rem; height: 1.25rem; }

    .required::after {
      content: " *";
      color: #b42318;
      font-weight: 700;
    }
    
    /* Progress and UI States */
    .progress-fill { transition: width .35s ease; }
    .success-view { display: none; }
    .success-view.show { display: block; animation: rise .5s ease both; }
    .form-view.hide { display: none; }
    
    .toast { display: none; }
    .toast.show { display: flex; animation: rise .25s ease both; }
    @keyframes rise {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @media (max-width: 640px) {
      .hero-copy { padding-top: 6.5rem; padding-bottom: 2rem; }
    }
  </style>
</head>

