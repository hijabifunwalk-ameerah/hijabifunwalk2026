      const addParticipantBtn = document.getElementById('add-participant-btn');
      
      const summaryList = document.getElementById('summary-list');
      const summaryTotal = document.getElementById('summary-total');
      
      const indCategorySelect = document.getElementById('ind-category-select');
      const indSizeSelect = document.getElementById('ind-size-select');
      const indGenderSelect = document.getElementById('ind-gender-select');
      const indGenderContainer = document.getElementById('ind-gender-container');
      const indIcContainer = document.getElementById('ind-ic-container');
      const indIcInput = document.getElementById('ind-ic-input');
      
      const fileInput = document.getElementById('payment-proof');
      const fileStatus = document.getElementById('file-status');
      const errorBox = document.getElementById('form-error');
      const successView = document.getElementById('success-view');
      const toast = document.getElementById('toast');
      const toastText = document.getElementById('toast-text');
      
      const telegramModal = document.getElementById('telegram-modal');
      const closeModalBtn = document.getElementById('close-modal-btn');
      const resetFormBtn = document.getElementById('reset-form-btn');
      
      closeModalBtn.addEventListener('click', () => {
        telegramModal.classList.add('hidden');
        telegramModal.classList.remove('flex');
      });
      
      const paymentMethodSelect = document.getElementById('payment-method-select');
      const paymentDetailsToyyibpay = document.getElementById('payment-details-toyyibpay');
      const paymentDetailsBank = document.getElementById('payment-details-bank');
      const paymentDetailsQr = document.getElementById('payment-details-qr');

      function getChildSizeOptions(gender) {
        const sleeve = gender === 'Lelaki' ? 'Lengan Pendek' : (gender === 'Perempuan' ? 'Lengan Panjang' : '');
        if (!sleeve) return '<option value="">Pilih jantina terlebih dahulu...</option>';
        
        return `
          <option value="">Pilih saiz</option>
          <option value="8XS (${sleeve})">8XS (${sleeve})</option>
          <option value="7XS (${sleeve})">7XS (${sleeve})</option>
          <option value="6XS (${sleeve})">6XS (${sleeve})</option>
          <option value="5XS (${sleeve})">5XS (${sleeve})</option>
          <option value="4XS (${sleeve})">4XS (${sleeve})</option>
          <option value="3XS (${sleeve})">3XS (${sleeve})</option>
          <option value="2XS (${sleeve})">2XS (${sleeve})</option>
        `;
      }

      resetFormBtn.addEventListener('click', () => {
        form.reset();
        successView.classList.remove('show');
        form.classList.remove('hide');
        
        individuSection.classList.add('hidden');
        keluargaSection.classList.add('hidden');
        emergencySection.classList.add('hidden');
        feeSection.classList.add('hidden');
        paymentSection.classList.add('hidden');
        confirmationSection.classList.add('hidden');
        paymentDetailsToyyibpay.classList.add('hidden');
        paymentDetailsBank.classList.add('hidden');
        paymentDetailsQr.classList.add('hidden');
        
        participantsContainer.innerHTML = '';
        participantCount = 0;
        
        indSizeSelect.innerHTML = '<option value="">Pilih kategori terlebih dahulu...</option>';
        indSizeSelect.disabled = true;
        indGenderContainer.classList.add('hidden');
        indIcContainer.classList.add('hidden');
        
        fileStatus.classList.add('hidden');
        fileInput.dataset.invalid = '';
        
        calculateTotal();
        updateProgress();
        
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      
      paymentMethodSelect.addEventListener('change', () => {
        const val = paymentMethodSelect.value;
        paymentDetailsToyyibpay.classList.add('hidden');
        paymentDetailsBank.classList.add('hidden');
        paymentDetailsQr.classList.add('hidden');
        
        if (val === 'toyyibpay') paymentDetailsToyyibpay.classList.remove('hidden');
        if (val === 'bank') paymentDetailsBank.classList.remove('hidden');
        if (val === 'qr') paymentDetailsQr.classList.remove('hidden');
      });
      
      let toastTimer;
      let participantCount = 0;

      function showToast(message) {
        toastText.textContent = message;
        toast.classList.add('show');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => toast.classList.remove('show'), 4200);
      }
      
      function handleRegTypeChange() {
        const type = document.querySelector('input[name="reg_type"]:checked')?.value;
        
        if (!type) return;

        emergencySection.classList.remove('hidden');
        feeSection.classList.remove('hidden');
        paymentSection.classList.remove('hidden');
        confirmationSection.classList.remove('hidden');
        
        const setRequired = (container, isReq) => {
          container.querySelectorAll('input:not([type="checkbox"]):not([type="radio"]), select, textarea').forEach(el => {
             if(el.id !== 'ind-gender-select' && !el.classList.contains('gender-select') && el.id !== 'ind-ic-input' && !el.classList.contains('ic-input')) {
               el.required = isReq;
             }
          });
        };
        
        document.querySelectorAll('.common-required').forEach(el => el.required = true);

        if (type === 'individu') {
          individuSection.classList.remove('hidden');
          keluargaSection.classList.add('hidden');
          setRequired(individuSection, true);
          setRequired(keluargaSection, false);
          
          handleIndCategoryChange(); 
        } else if (type === 'keluarga') {
          individuSection.classList.add('hidden');
          keluargaSection.classList.remove('hidden');
          setRequired(individuSection, false);
          setRequired(keluargaSection, true);
          
          if(participantCount === 0) addParticipant();
        }
        
        calculateTotal();
        updateProgress();
      }

      typeRadios.forEach(r => r.addEventListener('change', handleRegTypeChange));

      function handleIndCategoryChange() {
        const val = indCategorySelect.value;
        indSizeSelect.disabled = false;
        
        if (val === 'adult') {
          indSizeSelect.innerHTML = `
            <option value="">Pilih saiz</option>
            <option value="XS">XS</option><option value="S">S</option><option value="M">M</option><option value="L">L</option><option value="XL">XL</option>
            <option value="2XL">2XL</option>
            <option value="3XL">3XL (+RM5)</option><option value="4XL">4XL (+RM5)</option><option value="5XL">5XL (+RM5)</option>
            <option value="6XL">6XL (+RM5)</option><option value="7XL">7XL (+RM5)</option><option value="8XL">8XL (+RM5)</option><option value="9XL">9XL (+RM5)</option>
          `;
          indGenderContainer.classList.add('hidden');
          indGenderSelect.required = false;
          indGenderSelect.value = '';
          indIcContainer.classList.remove('hidden');
          const type = document.querySelector('input[name="reg_type"]:checked')?.value;
          indIcInput.required = (type === 'individu');
        } else if (val === 'child') {
          if (indGenderSelect.value) {
            indSizeSelect.innerHTML = getChildSizeOptions(indGenderSelect.value);
            indSizeSelect.disabled = false;
          } else {
            indSizeSelect.innerHTML = `<option value="">Pilih jantina terlebih dahulu...</option>`;
            indSizeSelect.disabled = true;
          }
          indGenderContainer.classList.remove('hidden');
          const type = document.querySelector('input[name="reg_type"]:checked')?.value;
          indGenderSelect.required = (type === 'individu');
          indIcContainer.classList.add('hidden');
          indIcInput.required = false;
          indIcInput.value = '';
        } else {
          indSizeSelect.innerHTML = `<option value="">Pilih kategori terlebih dahulu...</option>`;
          indSizeSelect.disabled = true;
          indGenderContainer.classList.add('hidden');
          indGenderSelect.required = false;
          indIcContainer.classList.add('hidden');
          indIcInput.required = false;
        }
        calculateTotal();
        updateProgress();
      }
      
      indCategorySelect.addEventListener('change', handleIndCategoryChange);
      
      indGenderSelect.addEventListener('change', () => {
        if (indCategorySelect.value === 'child') {
          if (indGenderSelect.value) {
            indSizeSelect.innerHTML = getChildSizeOptions(indGenderSelect.value);
            indSizeSelect.disabled = false;
          } else {
            indSizeSelect.innerHTML = `<option value="">Pilih jantina terlebih dahulu...</option>`;
            indSizeSelect.disabled = true;
          }
        }
        calculateTotal();
        updateProgress();
      });

      indSizeSelect.addEventListener('change', () => { calculateTotal(); updateProgress(); });

      window.removeParticipant = function(id) {
        const pCard = document.getElementById(`participant-${id}`);
        if (pCard) {
          pCard.remove();
          calculateTotal();
          updateProgress();
        }
      };

      function addParticipant() {
        participantCount++;
        const pId = participantCount;
        
        const deleteBtnHtml = pId > 1 
          ? `<button type="button" class="absolute top-4 right-4 text-red-500 hover:text-red-700 text-sm font-semibold flex items-center gap-1 transition-colors" onclick="window.removeParticipant(${pId})">
               <i data-lucide="trash-2" class="w-4 h-4"></i> Buang
             </button>` 
          : '';

        const html = `
          <div class="participant-card relative rounded-2xl border border-rose-200 bg-rose-50/50 p-5 pt-7" id="participant-${pId}">
            ${deleteBtnHtml}
            <h4 class="font-bold text-rose-900 mb-5 flex items-center gap-2">
              <span class="bg-rose-200 text-rose-800 rounded-full w-6 h-6 inline-flex items-center justify-center text-xs">${pId}</span>
              Ahli Keluarga ${pId}
            </h4>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              <div class="sm:col-span-2 lg:col-span-2">
                <label class="required block mb-2 text-sm font-semibold text-slate-700">Nama Penuh</label>
                <input type="text" name="p_name_${pId}" class="form-control" required>
              </div>
              <div>
                <label class="required block mb-2 text-sm font-semibold text-slate-700">Kategori</label>
                <select name="p_category_${pId}" class="form-control category-select" data-pid="${pId}" required>
                  <option value="">Pilih...</option>
                  <option value="adult">Dewasa (RM55)</option>
                  <option value="child">Kanak-kanak (RM40)</option>
                </select>
              </div>
              <div>
                <label class="required block mb-2 text-sm font-semibold text-slate-700">Saiz Baju</label>
                <select name="p_size_${pId}" class="form-control size-select" data-pid="${pId}" required disabled>
                  <option value="">Pilih kategori...</option>
                </select>
              </div>
              <div class="adult-ic-container hidden sm:col-span-2 lg:col-span-4" id="ic-container-${pId}">
                <label class="required block mb-2 text-sm font-semibold text-slate-700">No. Kad Pengenalan</label>
                <input type="text" name="p_ic_${pId}" class="form-control ic-input w-full lg:w-1/4" id="ic-input-${pId}" placeholder="Contoh: 900101-11-1234" maxlength="14">
              </div>
              <div class="child-gender-container hidden sm:col-span-2 lg:col-span-4" id="gender-container-${pId}">
                <label class="required block mb-2 text-sm font-semibold text-slate-700">Jantina (Kanak-kanak sahaja)</label>
                <select name="p_gender_${pId}" class="form-control gender-select w-full lg:w-1/4" id="gender-select-${pId}" data-pid="${pId}">
                  <option value="">Pilih jantina</option>
                  <option value="Lelaki">Lelaki</option>
                  <option value="Perempuan">Perempuan</option>
                </select>
              </div>
            </div>
          </div>
        `;
        
        participantsContainer.insertAdjacentHTML('beforeend', html);
        lucide.createIcons();
        updateProgress();
      }

      participantsContainer.addEventListener('change', (e) => {
        if (e.target.classList.contains('category-select')) {
          const pId = e.target.dataset.pid;
          const sizeSelect = document.querySelector(`.size-select[data-pid="${pId}"]`);
          const genderContainer = document.getElementById(`gender-container-${pId}`);
          const genderSelect = document.getElementById(`gender-select-${pId}`);
          const icContainer = document.getElementById(`ic-container-${pId}`);
          const icInput = document.getElementById(`ic-input-${pId}`);
          const val = e.target.value;

          sizeSelect.disabled = false;

          if (val === 'adult') {
            sizeSelect.innerHTML = `
              <option value="">Pilih saiz</option>
              <option value="XS">XS</option><option value="S">S</option><option value="M">M</option><option value="L">L</option><option value="XL">XL</option>
              <option value="2XL">2XL</option>
              <option value="3XL">3XL (+RM5)</option><option value="4XL">4XL (+RM5)</option><option value="5XL">5XL (+RM5)</option>
              <option value="6XL">6XL (+RM5)</option><option value="7XL">7XL (+RM5)</option><option value="8XL">8XL (+RM5)</option><option value="9XL">9XL (+RM5)</option>
            `;
            genderContainer.classList.add('hidden');
            genderSelect.required = false;
            genderSelect.value = '';
            icContainer.classList.remove('hidden');
            icInput.required = true;
          } else if (val === 'child') {
            if (genderSelect.value) {
              sizeSelect.innerHTML = getChildSizeOptions(genderSelect.value);
              sizeSelect.disabled = false;
            } else {
              sizeSelect.innerHTML = `<option value="">Pilih jantina terlebih dahulu...</option>`;
              sizeSelect.disabled = true;
            }
            genderContainer.classList.remove('hidden');
            genderSelect.required = true;
            icContainer.classList.add('hidden');
            icInput.required = false;
            icInput.value = '';
          } else {
            sizeSelect.innerHTML = `<option value="">Pilih kategori...</option>`;
            sizeSelect.disabled = true;
            genderContainer.classList.add('hidden');
            genderSelect.required = false;
            icContainer.classList.add('hidden');
            icInput.required = false;
          }
          
          calculateTotal();
          updateProgress();
        }

        if (e.target.classList.contains('gender-select')) {
          const pId = e.target.dataset.pid;
          const sizeSelect = document.querySelector(`.size-select[data-pid="${pId}"]`);
          const catSelect = document.querySelector(`.category-select[data-pid="${pId}"]`);
          
          if (catSelect.value === 'child') {
            if (e.target.value) {
              sizeSelect.innerHTML = getChildSizeOptions(e.target.value);
              sizeSelect.disabled = false;
            } else {
              sizeSelect.innerHTML = `<option value="">Pilih jantina terlebih dahulu...</option>`;
              sizeSelect.disabled = true;
            }
          }
          calculateTotal();
          updateProgress();
        }

        if (e.target.classList.contains('size-select')) {
          calculateTotal();
          updateProgress();
        }
      });

      addParticipantBtn.addEventListener('click', addParticipant);

      function calculateTotal() {
        const type = document.querySelector('input[name="reg_type"]:checked')?.value;
        if(!type) return;

        let total = 0;
        let adultCount = 0;
        let childCount = 0;
        let extraChargeCount = 0;

        if (type === 'individu') {
           const cat = indCategorySelect.value;
           const size = indSizeSelect.value;
           
           if(cat === 'adult') {
             adultCount++;
             total += 55;
             if (['3XL','4XL','5XL','6XL','7XL','8XL','9XL'].includes(size)) {
                extraChargeCount++;
                total += 5;
             }
           } else if (cat === 'child') {
             childCount++;
             total += 40;
           }
        } else if (type === 'keluarga') {
           document.querySelectorAll('.participant-card').forEach(card => {
            const cat = card.querySelector('.category-select').value;
            const size = card.querySelector('.size-select').value;

            if (cat === 'adult') {
              adultCount++;
              total += 55;
              if (['3XL','4XL','5XL','6XL','7XL','8XL','9XL'].includes(size)) {
                extraChargeCount++;
                total += 5; 
              }
            } else if (cat === 'child') {
              childCount++;
              total += 40;
            }
          });
        }

        let summaryHTML = '';
        if (adultCount > 0) {
          summaryHTML += `<div class="flex justify-between font-medium text-rose-900 mb-1.5"><span>Dewasa (RM55) x ${adultCount}</span><span>RM ${adultCount * 55}</span></div>`;
        }
        if (childCount > 0) {
          summaryHTML += `<div class="flex justify-between font-medium text-rose-900 mb-1.5"><span>Kanak-kanak (RM40) x ${childCount}</span><span>RM ${childCount * 40}</span></div>`;
        }
        if (extraChargeCount > 0) {
          summaryHTML += `<div class="flex justify-between text-amber-600 font-medium text-sm mb-1"><span>Caj Saiz Besar (+RM5) x ${extraChargeCount}</span><span>RM ${extraChargeCount * 5}</span></div>`;
        }

        if (summaryHTML === '') {
          summaryList.innerHTML = '<div class="text-slate-500 italic">Sila tambah peserta dan lengkapkan butiran.</div>';
          summaryTotal.textContent = 'RM 0';
        } else {
          summaryList.innerHTML = summaryHTML;
          summaryTotal.textContent = `RM ${total}`;
        }
      }

      function updateProgress() {
        const type = document.querySelector('input[name="reg_type"]:checked')?.value;
        let requiredFields = [];
        
        requiredFields.push(...form.querySelectorAll('input[name="reg_type"]'));
        
        if (type) {
           const activeSection = type === 'individu' ? individuSection : keluargaSection;
           requiredFields.push(...activeSection.querySelectorAll('[required]'));
           requiredFields.push(...emergencySection.querySelectorAll('[required]'));
           requiredFields.push(...paymentSection.querySelectorAll('[required]'));
           requiredFields.push(...confirmationSection.querySelectorAll('[required]'));
        }
        
        if (!requiredFields.length) {
          progressFill.style.width = '0%';
          progressText.textContent = '0%';
          return;
        }

        const uniqueRequiredFields = [];
        const seenNames = new Set();
        
        requiredFields.forEach(el => {
           if(el.type === 'radio') {
             if(!seenNames.has(el.name)) {
                seenNames.add(el.name);
                uniqueRequiredFields.push(el);
             }
           } else {
             uniqueRequiredFields.push(el);
           }
        });

        const completed = uniqueRequiredFields.filter(el => {
          if (el.type === 'radio') return !!form.querySelector(`input[name="${el.name}"]:checked`);
          if (el.type === 'checkbox') return el.checked;
          if (el.type === 'file') return el.files && el.files.length > 0 && !el.dataset.invalid;
          return el.value.trim() !== '';
        }).length;

        const percentage = Math.round((completed / uniqueRequiredFields.length) * 100);
        progressFill.style.width = percentage + '%';
        progressText.textContent = percentage + '%';
      }

      function validateFile() {
        fileStatus.classList.add('hidden');
        fileInput.dataset.invalid = '';

        const file = fileInput.files[0];
        if (!file) {
          updateProgress();
          return true;
        }

        const validTypes = ['image/jpeg', 'image/png', 'application/pdf'];
        const validExtensions = /\.(jpg|jpeg|png|pdf)$/i;
        const isValidType = validTypes.includes(file.type) || validExtensions.test(file.name);
        const isValidSize = file.size <= 10 * 1024 * 1024;

        if (!isValidType || !isValidSize) {
          fileInput.dataset.invalid = 'true';
          fileStatus.textContent = !isValidType
            ? 'Fail tidak disokong. Sila pilih JPG, PNG atau PDF.'
            : 'Saiz fail melebihi had 10MB.';
          fileStatus.className = 'mt-2 text-sm font-semibold text-red-700';
          updateProgress();
          return false;
        }

        fileStatus.textContent = 'Bukti pembayaran dipilih: ' + file.name;
        fileStatus.className = 'mt-2 text-sm font-semibold text-rose-600';
        updateProgress();
        return true;
      }

      form.addEventListener('input', updateProgress);
      form.addEventListener('change', updateProgress);
      fileInput.addEventListener('change', validateFile);

      function getBase64(file) {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.readAsDataURL(file);
          reader.onload = () => resolve(reader.result.split(',')[1]); 
          reader.onerror = error => reject(error);
        });
      }

      form.addEventListener('submit', async event => {
        event.preventDefault();
        errorBox.classList.add('hidden');
        
        const type = document.querySelector('input[name="reg_type"]:checked')?.value;
        if (!type) {
           errorBox.textContent = 'Sila pilih jenis pendaftaran (Individu / Keluarga) di Langkah 1.';
           errorBox.classList.remove('hidden');
           return;
        }

        if (type === 'keluarga') {
            const participantCards = document.querySelectorAll('.participant-card');
            if (participantCards.length === 0) {
               errorBox.textContent = 'Sila tambah sekurang-kurangnya satu peserta ahli keluarga.';
               errorBox.classList.remove('hidden');
               return;
            }
        }

        if (!validateFile()) {
          errorBox.textContent = 'Sila betulkan fail bukti pembayaran sebelum menghantar borang.';
          errorBox.classList.remove('hidden');
          return;
        }

        if (!form.checkValidity()) {
          errorBox.textContent = 'Sila lengkapkan semua medan wajib dan pengesahan sebelum menghantar borang.';
          errorBox.classList.remove('hidden');
          
          const firstInvalid = form.querySelector(':invalid');
          if (firstInvalid) {
            firstInvalid.focus();
            firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          return;
        }

        const submitBtn = document.getElementById('submit-button');
        const originalBtnText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i data-lucide="loader-2" class="h-5 w-5 animate-spin"></i> Sedang Dihantar...';
        submitBtn.disabled = true;
        lucide.createIcons(); 

        try {
          const type = document.querySelector('input[name="reg_type"]:checked').value;
          let payload = {
            reg_type: type,
            name: type === 'individu' ? form.ind_name.value : form.head_name.value,
            phone: type === 'individu' ? form.ind_phone.value : form.head_phone.value,
            email: type === 'individu' ? form.ind_email.value : form.head_email.value,
            address: type === 'individu' ? 
              `${form.ind_address.value}, ${form.ind_city.value}, ${form.ind_postcode.value} ${form.ind_state.value}` : 
              `${form.head_address.value}, ${form.head_city.value}, ${form.head_postcode.value} ${form.head_state.value}`,
            emergency: `${form.emergency_name.value} (${form.emergency_phone.value} - ${form.emergency_relation.value})`,
            total_amount: document.getElementById('summary-total').textContent,
            payment_method: form.querySelector('#payment-method-select').value
          };

          if (type === 'individu') {
            payload.participants = `[Individu] Kategori: ${form.ind_category.value}, Saiz: ${form.ind_size.value}, Jantina: ${form.ind_gender.value || 'N/A'}, No. KP: ${form.ind_ic.value || 'N/A'}`;
          } else {
            let pList = [];
            document.querySelectorAll('.participant-card').forEach((card, idx) => {
              const pName = card.querySelector('input[type="text"]').value;
              const pCat = card.querySelector('.category-select').value;
              const pSize = card.querySelector('.size-select').value;
              const pGen = card.querySelector('.gender-select').value;
              const pIc = card.querySelector('.ic-input').value;
              pList.push(`${idx + 1}. ${pName} (${pCat}, Saiz: ${pSize}, Jantina: ${pGen || 'N/A'}, No. KP: ${pIc || 'N/A'})`);
            });
            payload.participants = pList.join('\n');
          }

          const file = fileInput.files[0];
          if (file) {
            payload.fileBase64 = await getBase64(file);
            payload.fileName = file.name;
            payload.fileMimeType = file.type;
          }

          if(!SCRIPT_URL || SCRIPT_URL.includes("YOUR_SCRIPT_URL_HERE")) {
              throw new Error("URL Web App (Google Apps Script) belum dikonfigurasi dengan betul dalam kod.");
          }

          const response = await fetch(SCRIPT_URL, {
            method: 'POST',
            body: JSON.stringify(payload),
            headers: { 'Content-Type': 'text/plain;charset=utf-8' } 
          });

          const result = await response.json();
          
          if (result.status === 'success') {
            form.classList.add('hide');
            successView.classList.add('show');
            successView.scrollIntoView({ behavior: 'smooth', block: 'start' });
            
            setTimeout(() => {
              telegramModal.classList.remove('hidden');
              telegramModal.classList.add('flex');
            }, 500);
          } else {
            throw new Error(result.message || 'Sistem gagal menyimpan rekod.');
          }
        } catch (err) {
          console.error(err);
          errorBox.textContent = 'Gagal menghantar borang. ' + err.message;
          errorBox.classList.remove('hidden');
        } finally {
          submitBtn.innerHTML = originalBtnText;
          submitBtn.disabled = false;
        }
      });

      updateProgress();
    });
  </script>
</body>
